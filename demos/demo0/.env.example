# ─── AWS credentials ─────────────────────────────────────────────────────────
# Leave blank if running on EC2 with an IAM instance profile
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Bedrock model (overrides config.yaml default) ───────────────────────────
# Must have cross-region inference enabled
BEDROCK_MODEL_ID=

# ─── Memory backend ──────────────────────────────────────────────────────────
# "local"     → JSON files in agents/demoN/data/memory/
# "agentcore" → Amazon Bedrock AgentCore Memory (requires EP-7)
MEMORY_BACKEND=local

# ─── Human-in-the-loop timeout (seconds) ─────────────────────────────────────
# Default: 86400 (24 hours)
APPROVAL_TIMEOUT_SECONDS=86400

# ─── Python / Windows ────────────────────────────────────────────────────────
# Force UTF-8 for all Python I/O on Windows
PYTHONUTF8=1
# Suppress OTel ContextVar errors from Strands async generator teardown
OTEL_SDK_DISABLED=true

# ─── Platform auth (local credentials) ───────────────────────────────────────
# Username and password for the Sign In flow on the marketplace UI.
# These are checked server-side by POST /api/auth/login.
AUTH_USERNAME=
AUTH_PASSWORD=
