# Runtime data written by this agent during a run.
# Each new agent copies this file and adds/removes paths to match what
# its pipeline writes. Anything seed/fixture (e.g. data/dummy/, data/test_scenarios/)
# stays tracked; anything generated by an actual run goes here.

# Per-session and per-run state + event logs
data/sessions/

# Agent memory store
data/memory/

# Per-case folders, if the agent uses cases
data/cases/

# User uploads
data/uploads/

# Run-id daily counter
data/_run_seq/

# Append-only audit logs
data/logs/
