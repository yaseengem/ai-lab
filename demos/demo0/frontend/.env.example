# ─── Mock API ────────────────────────────────────────────────────────────────
# Set to "true" to run the frontend without a live backend (Sprint 1 / demo).
# Set to "false" when the FastAPI services are running.
VITE_USE_MOCK_API=true

# ─── Backend URLs ─────────────────────────────────────────────────────────────
# Change to your EC2 hostname / IP for production.
VITE_CLAIMS_API_URL=http://localhost:8001
VITE_UNDERWRITING_API_URL=http://localhost:8002
VITE_LOAN_API_URL=http://localhost:8003
