# This file only lists what is shared (logs and the Vite .env).
**/logs/
**/frontend/.env

# Platform logs (demo0 scanner backend)
**/app/logs/

# Root-level legacy folders (deleted in A14 — kept here in case of accidental recreation)
logs/
storage/

# Frontend build output (AI Lab launcher + per-demo frontends)
**/frontend/dist/
frontend/.env
**/install.log
# Note: frontend/public/demos.json is committed as a default and regenerated
# from config.yaml by run.sh — it is intentionally NOT ignored.

